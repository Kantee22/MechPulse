    {
        "id": "build_sql",
        "type": "function",
        "z": "mechpulse",
        "name": "Build SQL",
        "func": "const d = msg.payload;\n\nlet score = 100;\nif (d.vib_count > 0) score -= d.vib_count * 5;\nif (d.knock_count > 0) score -= d.knock_count * 10;\nif (d.sound_var > 100) score -= 4;\n\nconst hour = new Date().getHours();\nlet temp = 27;\nif (hour >= 6 && hour <= 9) temp = 28 + Math.random() * 3;\nelse if (hour >= 10 && hour <= 16) temp = 32 + Math.random() * 6;\nelse if (hour >= 17 && hour <= 21) temp = 30 + Math.random() * 4;\nelse temp = 26 + Math.random() * 3;\n\nif (temp > 38) score -= 3;\nscore = Math.max(0, Math.min(100, score + Math.floor(Math.random() * 5 - 2)));\n\nlet status = 'normal';\nif (score < 60) status = 'critical';\nelse if (score < 85) status = 'warning';\n\nmsg.topic = `INSERT INTO sensor_data (phase, cycle, vib_count, knock_count, sound_avg, sound_var, temperature, health_score, status) VALUES ('${d.phase}', ${d.cycle}, ${d.vib_count}, ${d.knock_count}, ${d.sound_avg || 0}, ${d.sound_var}, ${temp.toFixed(1)}, ${score}, '${status}')`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 590,
        "y": 480,
        "wires": [
            [
                "mysql"
            ]
        ]
    },
