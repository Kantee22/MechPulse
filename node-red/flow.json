    {
        "id": "weather_parse_new",
        "type": "function",
        "z": "mechpulse",
        "name": "Parse Weather",
        "func": "const d = msg.payload;\n\nif (!d || !d.current) {\n    node.warn('No weather data');\n    return null;\n}\n\nconst temp = d.current.temp_c;\nconst humidity = d.current.humidity;\nconst pressure = Math.round(d.current.pressure_mb);\nconst desc = d.current.condition.text.toLowerCase();\nconst wind = d.current.wind_kph / 3.6;\nconst city = d.location.name;\n\nconst descSafe = desc.replace(/'/g, \"''\");\n\nmsg.topic = `INSERT INTO weather_data (city, temp_outside, humidity, pressure, weather_desc, wind_speed) VALUES ('${city}', ${temp}, ${humidity}, ${pressure}, '${descSafe}', ${wind.toFixed(1)})`;\n\nreturn msg;",
        "outputs": 1,
        "x": 740,
        "y": 760,
        "wires": [
            [
                "weather_mysql_new"
            ]
        ]
