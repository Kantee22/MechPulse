        "z": "mechpulse",
        "name": "function 1",
        "func": "const limit = Math.min(parseInt(msg.req.query.limit) || 2000, 20000);\nconst phase = msg.req.query.phase;\nlet sql = \"SELECT * FROM `sensor_data`\";\nif (phase) sql += ` WHERE phase = ${JSON.stringify(phase)}`;\nsql += ` ORDER BY timestamp DESC LIMIT ${limit}`;\nmsg.topic = sql;\nreturn msg;",
