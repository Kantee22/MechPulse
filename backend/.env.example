# Primary data source: Node-RED HTTP API
# Node-RED runs on the KU server and proxies reads from MySQL (which is
# locked to localhost). HTTPS (443) is open to the internet so this works
# from anywhere. Replace the student ID with your own if needed.
API_BASE=https://iot.cpe.ku.ac.th/red/b6710545440
API_SENSOR_PATH=/api/sensor
API_WEATHER_PATH=/api/weather
API_TIMEOUT=12

# Table names - only used for display and for sync_snapshot.py (direct MySQL).
SENSOR_TABLE=sensor_data
WEATHER_TABLE=weather_data

# Optional: direct MySQL credentials. Only needed if you run sync_snapshot.py
# on campus to cache data into snapshot.db.
DB_HOST=iot.cpe.ku.ac.th
DB_PORT=3306
DB_USER=b6710545440
DB_PASSWORD=changeme
DB_NAME=b6710545440

# Comma-separated list of origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Reference values from the machine's manufacturer spec (secondary data source).
# Used by the health-score and anomaly-detection endpoints.
REF_TEMP_C=45
REF_VIB_COUNT=5
REF_SOUND_AVG=870
REF_SOUND_VAR=60
